{
  "schema_version": 5,
  "classification_order": [
    "large_or_high_risk",
    "mechanical",
    "simple",
    "standard"
  ],
  "match_semantics": "first_match",
  "orchestration_modes": {
    "default": "model_economy",
    "selection_scope": "current_task_only",
    "modes": {
      "model_economy": {
        "trigger": "default",
        "task_class_policy_applies": true,
        "native_quality_gates_apply": true,
        "model_economy_roles": "per_task_class"
      },
      "superpowers_strict": {
        "trigger": {
          "operator": "explicit_user_request",
          "phrases": [
            "完整 Superpowers",
            "本任务使用完整 Superpowers",
            "full Superpowers",
            "Superpowers strict mode"
          ]
        },
        "task_class_policy_applies": false,
        "native_quality_gates_apply": false,
        "model_economy_roles": "forbidden",
        "model_economy_scope": ["model_advice", "cost_advice"]
      }
    }
  },
  "task_classes": {
    "large_or_high_risk": {
      "label": "大型/高风险",
      "match": {
        "operator": "any",
        "predicates": ["high_risk", "new_architecture", "wide_blast_radius"]
      },
      "primary_execution": {
        "selection": "exactly_one",
        "choices": ["main_agent", "model-economy-implementer"]
      },
      "base_allowed_roles": [
        "model-economy-implementer",
        "model-economy-explorer"
      ],
      "conditional_roles": [],
      "required_roles": [
        {
          "role": "model-economy-architect",
          "when": "before_design_approval",
          "must_complete_before": "design_approval"
        },
        {
          "role": "model-economy-final-reviewer",
          "when": "after_verification",
          "must_complete_before": "task_completion"
        }
      ],
      "forbidden_roles": [
        "model-economy-reviewer",
        "model-economy-batch-worker"
      ],
      "strong_max": 2
    },
    "mechanical": {
      "label": "机械",
      "match": {
        "operator": "all",
        "predicates": [
          "deterministic_input_targets_and_rules",
          "independent_retryable_operations",
          "no_sensitive_or_high_risk_boundary",
          "automated_check_per_result",
          "bounded_explicit_failure"
        ]
      },
      "primary_execution": {
        "selection": "exactly_one",
        "choices": ["model-economy-batch-worker"]
      },
      "base_allowed_roles": ["model-economy-batch-worker"],
      "conditional_roles": [],
      "required_roles": [],
      "forbidden_roles": [
        "model-economy-architect",
        "model-economy-final-reviewer",
        "model-economy-implementer",
        "model-economy-reviewer",
        "model-economy-explorer"
      ],
      "strong_max": 0
    },
    "simple": {
      "label": "简单",
      "match": {
        "operator": "all",
        "predicates": [
          "known_files",
          "no_open_judgment",
          "directly_verifiable",
          "not_creative_or_behavioral_change"
        ]
      },
      "primary_execution": {
        "selection": "exactly_one",
        "choices": ["main_agent"]
      },
      "base_allowed_roles": [],
      "conditional_roles": [],
      "required_roles": [],
      "forbidden_roles": [
        "model-economy-architect",
        "model-economy-final-reviewer",
        "model-economy-implementer",
        "model-economy-reviewer",
        "model-economy-explorer",
        "model-economy-batch-worker"
      ],
      "strong_max": 0
    },
    "standard": {
      "label": "标准",
      "match": {
        "operator": "default",
        "predicates": []
      },
      "primary_execution": {
        "selection": "exactly_one",
        "choices": ["main_agent", "model-economy-implementer"]
      },
      "base_allowed_roles": [
        "model-economy-implementer"
      ],
      "conditional_roles": [
        {
          "role": "model-economy-explorer",
          "when": {
            "operator": "any",
            "predicates": [
              "file_location_uncertain",
              "dependency_relationship_uncertain",
              "existing_facts_uncertain"
            ]
          },
          "output": "minimal_facts"
        },
        {
          "role": "model-economy-reviewer",
          "when": {
            "operator": "any",
            "predicates": [
              "cross_module_change",
              "critical_logic_change",
              "non_obvious_regression_risk",
              "material_test_coverage_doubt"
            ]
          },
          "output": "independent_findings"
        },
        {
          "role": "model-economy-architect",
          "when": {
            "failed_attempts": {"gte": 2}
          },
          "max_calls": 1,
          "output": "diagnostic_decision",
          "after_completion": {
            "implementation_capability": "balanced",
            "reclassify_when": "large_or_high_risk_discovered",
            "counts_as_large_architect_when": [
              "before_new_design_approval",
              "large_architect_output_contract_satisfied"
            ]
          }
        }
      ],
      "required_roles": [],
      "forbidden_roles": [
        "model-economy-final-reviewer",
        "model-economy-batch-worker"
      ],
      "strong_max": 1
    }
  },
  "lightweight_practices": {
    "orchestration_authority": "model_economy",
    "classification_effect": "none",
    "subagent_starts": 0,
    "skills": {
      "domain-context": {
        "skill": "domain-context",
        "trigger": {
          "operator": "any",
          "conditions": [
            {"predicate": "domain_vocabulary_unclear"},
            {"predicate": "domain_invariants_relevant"},
            {"predicate": "domain_docs_or_adrs_relevant"}
          ]
        },
        "allowed_outputs": [
          "shared_vocabulary",
          "domain_invariants",
          "documented_constraint_conflicts"
        ]
      },
      "module-design": {
        "skill": "module-design",
        "trigger": {
          "operator": "any",
          "conditions": [
            {"predicate": "module_boundary_under_review"},
            {"predicate": "coupling_or_change_surface_problem"},
            {"predicate": "architecture_improvement_requested"}
          ]
        },
        "allowed_outputs": [
          "boundary_findings",
          "interface_tradeoffs",
          "smallest_structural_improvement"
        ]
      },
      "disposable-prototype": {
        "skill": "disposable-prototype",
        "trigger": {
          "operator": "any",
          "conditions": [
            {"predicate": "prototype_explicitly_requested"},
            {
              "operator": "all",
              "conditions": [
                {"predicate": "concrete_design_unknown"},
                {"predicate": "small_experiment_cheaper_than_discussion"}
              ]
            }
          ]
        },
        "allowed_outputs": [
          "isolated_experiment",
          "observed_result",
          "production_decision_input"
        ]
      }
    }
  },
  "approval_gate": {
    "required_when": [
      "material_ambiguity",
      "materially_different_outcomes",
      "high_risk_decision",
      "unapproved_architecture_boundary"
    ],
    "required_evidence": ["approved_design", "approval_evidence"],
    "forbidden_without_evidence": ["implementation"],
    "not_repeated_when": [
      "clear_goal_constraints_and_acceptance",
      "reproducible_bugfix",
      "implementation_within_approved_design",
      "literal_change",
      "deterministic_mechanical_change"
    ]
  },
  "quality_gates": {
    "intent": "conditional_before_implementation",
    "planning": "scaled_by_task_class",
    "testing": "scaled_by_behavioral_risk",
    "evidence": "required_before_completion_claim"
  },
  "economy_conditions": [
    {
      "id": "deterministic_input_targets_and_rules",
      "required": true
    },
    {
      "id": "independent_retryable_operations",
      "required": true
    },
    {
      "id": "no_sensitive_or_high_risk_boundary",
      "required": true
    },
    {
      "id": "automated_check_per_result",
      "required": true
    },
    {
      "id": "bounded_explicit_failure",
      "required": true
    }
  ],
  "roles": {
    "model-economy-architect": {
      "capability": "strong",
      "write_access": "read_only",
      "allowed_outputs": ["architecture_boundaries", "risks", "decisions"],
      "forbidden_outputs": ["plans", "patches", "code"]
    },
    "model-economy-final-reviewer": {
      "capability": "strong",
      "write_access": "read_only",
      "allowed_outputs": ["findings", "evidence_gaps", "residual_risks"],
      "forbidden_outputs": ["patches", "code"]
    },
    "model-economy-implementer": {
      "capability": "balanced",
      "write_access": "workspace_write",
      "allowed_outputs": ["approved_scope_implementation", "tests", "verification"],
      "forbidden_outputs": ["unapproved_design", "unapproved_plan"]
    },
    "model-economy-reviewer": {
      "capability": "balanced",
      "write_access": "read_only",
      "allowed_outputs": ["findings", "regression_risks", "test_gaps"],
      "forbidden_outputs": ["plans", "patches", "code"]
    },
    "model-economy-explorer": {
      "capability": "economy",
      "write_access": "read_only",
      "allowed_outputs": ["file_inventory", "facts", "constraints"],
      "forbidden_outputs": ["designs", "plans", "patches", "code"]
    },
    "model-economy-batch-worker": {
      "capability": "economy",
      "write_access": "workspace_write",
      "allowed_outputs": ["fixed_rule_edits", "per_item_checks"],
      "forbidden_outputs": ["designs", "plans", "semantic_judgment"]
    }
  },
  "context_sanitization": {
    "remove_before_sending": [
      "secrets",
      "tokens",
      "personal_data",
      "production_data",
      "internal_urls",
      "irrelevant_paths"
    ],
    "placeholder_format": "[REDACTED_<TYPE>]"
  },
  "delegation": {
    "max_subagent_starts_per_task": 3,
    "max_concurrent_subagents": 3,
    "reclassification_resets_budget": false,
    "recursive_delegation": "forbidden",
    "write_file_sets": {
      "must_be_mutually_exclusive": true,
      "overlap_handling": "main_agent_serializes"
    }
  }
}
